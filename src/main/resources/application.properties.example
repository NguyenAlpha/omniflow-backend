spring.application.name=omniflow-backend

# Database
spring.datasource.url=jdbc:postgresql://localhost:5432/omniflow
spring.datasource.username=omniflow
spring.datasource.password=CHANGE_ME
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true

# JWT
jwt.secret=CHANGE_ME
jwt.expiration=86400000

# System admin seed
admin.seed.enabled=false
admin.seed.username=admin
admin.seed.email=admin@admin.local
admin.seed.password=CHANGE_ME
admin.seed.full-name=System Admin
admin.seed.role=SUPER_ADMIN
admin.seed.department=System
admin.seed.phone=
admin.seed.active=true

